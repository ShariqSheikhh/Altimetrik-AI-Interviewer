# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Bedrock (AI Interviewer + Evaluator)
REGION=us-east-1
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
MODEL_NAME=amazon.nova-lite-v1:0

# AWS S3 (Video Storage)
REGION=us-east-1
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Optional: CloudFront distribution for video playback (recommended for production)
CLOUDFRONT_URL=

# Support Email
SUPPORT_MAIL=

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@altimetrik.com
